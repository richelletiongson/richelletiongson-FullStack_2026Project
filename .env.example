# Copy to .env.local (create the file) and set DATABASE_URL.
#
# Supabase — Direct (dev / long-lived server), from Connect → DATABASE → Direct connection string:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# Supabase — Pooler (Vercel / serverless), from Connect → use pooled / Transaction:
# DATABASE_URL=postgresql://postgres.<project-ref>:YOUR_PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
#
# Local Postgres:
# DATABASE_URL=postgresql://username:password@localhost:5432/horoscope2026
PORT=3000

# Supabase (browser-safe; required for Supabase client usage)
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Use either key name (same anon/public JWT from Supabase dashboard):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
