<main class="page-main">
  <div class="page-wrap">
    <p class="page-subtitle">Horoscope 2026</p>
    <form action="/forecast" method="get" class="landing-form">
      <div class="landing-row">
        <span class="text">I'm</span>
        <select name="sign" required class="prettySelect">
          <option value="">choose sign</option>
          <% signs.forEach(function(s) { %>
            <option value="<%= s %>"><%= s %></option>
          <% }); %>
        </select>
        <span class="text">, and I'd love to know what the stars have in store for my</span>
      </div>
      <div class="landing-row">
        <span class="text">Category:</span>
      </div>

      <!-- Hidden native select used for form submission; kept in sync with slider -->
      <select
        name="category"
        required
        class="prettySelect"
        style="position:absolute;opacity:0;pointer-events:none;width:0;height:0;"
      >
        <% categories.forEach(function(c) { %>
          <option value="<%= c.value %>"><%= c.label %></option>
        <% }); %>
      </select>

      <!-- Pretty static category cards -->
      <div style="width:100%;margin-top:1.75rem;">
        <div class="ccs-root" aria-label="Choose a category" data-selected="">
          <div class="ccs-gallery" role="group" aria-roledescription="carousel">
            <ul class="ccs-cards" aria-label="Categories">
              <% categories.forEach(function(c, idx) { %>
                <li
                  class="ccs-card"
                  data-value="<%= c.value %>"
                  style="--ccs-accent: <%= c.accent || ['#cdb4ff','#ffe08a','#ffb3d9','#9a7cf6'][idx % 4] %>;"
                >
                  <button
                    type="button"
                    class="ccs-cardButton"
                    aria-pressed="false"
                  >
                    <span class="ccs-cardLabel"><%= c.label %></span>
                    <% if (c.description) { %>
                      <span class="ccs-cardDesc"><%= c.description %></span>
                    <% } %>
                  </button>
                </li>
              <% }); %>
            </ul>
            <div class="ccs-actions" aria-label="Slider controls">
              <button type="button" class="ccs-navBtn" data-dir="prev" aria-label="Previous">
                ←
              </button>
              <button type="button" class="ccs-navBtn" data-dir="next" aria-label="Next">
                →
              </button>
            </div>
          </div>
        </div>
      </div>
      <div class="landing-row">
        <span class="text">in</span>
        <select name="month_id" required class="prettySelect">
          <option value="">month</option>
          <% months.forEach(function(m) { %>
            <option value="<%= m.month_id %>"><%= m.name %></option>
          <% }); %>
        </select>
      </div>
      <button type="submit" class="forecastBtn">See my forecast</button>
    </form>
    <p class="sign-links">
      <% signs.forEach(function(s, i) { %>
        <a href="/sign/<%= encodeURIComponent(s) %>" class="sign-link"><%= s %></a><%= i < signs.length - 1 ? ' · ' : '' %>
      <% }); %>
    </p>
  </div>
</main>
